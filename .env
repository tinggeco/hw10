
# =========================================================
# Week 10 Homework — ARIA v7.0
# Environment Configuration File
# Study Area: Hualien Matai'an Creek Basin
# =========================================================

# ---------------------------------------------------------
# 1. Study Area BBOX
# ---------------------------------------------------------
# 左上 (23.7447, 121.2574)
# 右下 (23.6546, 121.4984)

BBOX_WEST=121.2574
BBOX_SOUTH=23.6546
BBOX_EAST=121.4984
BBOX_NORTH=23.7447


# ---------------------------------------------------------
# 2. Time Range
# ---------------------------------------------------------
# 災前基準期（颱風前）

PRE_DATE_RANGE=2025-10-01/2025-11-05

# 災後觀測期（颱風後）

POST_DATE_RANGE=2025-11-12/2025-11-30


# ---------------------------------------------------------
# 3. Threshold Parameters
# ---------------------------------------------------------

# Sentinel-1 SAR flood threshold
# ARIA 預設值，可依直方圖調整

SAR_THRESHOLD=-15

# NDWI threshold
# 清水常用 0.3
# 若濁水嚴重可調整至 0.0 ~ 0.2

NDWI_THRESHOLD=0.3

# Topographic slope threshold
# 超過此坡度通常不可能積水

SLOPE_THRESHOLD=25

# Connected component minimum size
# 小於此值視為雜訊移除
# 50 pixels = 0.5 ha

MIN_WATER_PIXELS=50